# ─── Enricher Settings ────────────────────────────
# Number of companies to search per Gemini query
ENRICHER_BATCH_SIZE=200

# Max wait time for Gemini response (in seconds)
# Large batches (100-200) need more time for thinker mode
ENRICHER_MAX_WAIT=600

# Delay between batches (in milliseconds)
ENRICHER_BATCH_DELAY=3000