# ╔══════════════════════════════════════════════════════════╗
# ║  VikiLeads Apollo Scraper — Configuration               ║
# ║  Copy .env.example → .env, edit for your machine, run:  ║
# ║    npm install && node server.js                        ║
# ╚══════════════════════════════════════════════════════════╝

# ─── Server ───────────────────────────────────────────────
SERVER_PORT=3000

# ─── Chrome Browser ───────────────────────────────────────
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Mac:     /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Chrome user data (your profile with Apollo login)
# Windows: C:\Users\YourName\AppData\Local\Google\Chrome\User Data
# Mac:     ~/Library/Application Support/Google/Chrome
# Linux:   ~/.config/google-chrome
CHROME_USER_DATA=C:\Users\Hassan\AppData\Local\Google\Chrome\User Data

# Chrome remote debugging port
CHROME_DEBUG_PORT=9222

# ─── Scraper Timing ──────────────────────────────────────
SCRAPER_PAGE_DELAY_MIN=1500
SCRAPER_PAGE_DELAY_MAX=3000
SCRAPER_RATE_LIMIT_WAIT=30
SCRAPER_RETRY_DELAY=3000

# ─── Website Enricher (Gemini) ───────────────────────────
ENRICHER_BATCH_SIZE=200
ENRICHER_MAX_WAIT=600
ENRICHER_BATCH_DELAY=3000
ENRICHER_GEMINI_COOLDOWN=30

# ─── Company Enricher (Apollo bulk_enrich) ───────────────
ENRICHER_COMPANY_BATCH_SIZE=10

# ─── Watcher ─────────────────────────────────────────────
ENRICHER_POLL_INTERVAL=10